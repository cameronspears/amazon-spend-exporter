{
  "name": "amazon-orders",
  "version": "0.1.0",
  "description": "Local CLI to export Amazon.com order history to CSV/XLSX",
  "license": "MIT",
  "bin": {
    "amazon-orders": "dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:core && npm run web:build",
    "build:core": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "app": "npm run build && node dist/server/index.js",
    "app:dev": "tsx src/server/index.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:dev": "vite --config web/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cheerio": "^1.1.2",
    "commander": "^14.0.2",
    "express": "^4.21.2",
    "playwright": "^1.55.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.23",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.4.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^5.4.10",
    "vitest": "^3.2.4"
  }
}
